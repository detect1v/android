<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0A0A1A"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="КОМПАС"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#E0E0E0"
        android:letterSpacing="0.3"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvDirection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Північ"
        android:textSize="22sp"
        android:textColor="#FFD700"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <FrameLayout
        android:layout_width="280dp"
        android:layout_height="280dp">

        <ImageView
            android:id="@+id/ivCompassRose"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/compass_rose"/>

        <ImageView
            android:id="@+id/ivArrow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/compass_arrow"/>

    </FrameLayout>

    <TextView
        android:id="@+id/tvDegrees"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0°"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvAccuracy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Точність: —"
        android:textSize="13sp"
        android:textColor="#9E9E9E"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvSensorInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Акселерометр: —\nМагнітометр: —"
        android:textSize="12sp"
        android:textColor="#616161"
        android:gravity="center"
        android:layout_marginTop="16dp"/>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#FAFAFA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Медіаплеєр"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Оберіть джерело файлу"
        android:textSize="14sp"
        android:textColor="#9E9E9E"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnPickAudio"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:text="🎵  Аудіо зі сховища"
        android:backgroundTint="#1976D2"
        android:textColor="#FFFFFF"
        android:textSize="15sp"/>

    <Button
        android:id="@+id/btnPickVideo"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:text="🎬  Відео зі сховища"
        android:backgroundTint="#388E3C"
        android:textColor="#FFFFFF"
        android:textSize="15sp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginVertical="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="або введіть URL з інтернету"
        android:textSize="13sp"
        android:textColor="#9E9E9E"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="https://example.com/video.mp4"
        android:inputType="textUri"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:textSize="13sp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnPlayUrl"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="▶  Відтворити URL"
        android:backgroundTint="#F57C00"
        android:textColor="#FFFFFF"
        android:textSize="15sp"/>

</LinearLayout>